{
  "For Loop": {
    "prefix": "for",
    "body": [
      "for(${1:int} ${2:i} = ${3:0}; ${2:i} < ${4:max}; ${2:i}++) {",
      "\t$0",
      "}"
    ],
    "description": "Creates a for loop"
  },
  "main": {
    "prefix": "main",
    "body": ["void main(){", "\t$0", "}"],
    "description": "Creates the main function"
  },
  "if": {
    "prefix": "if",
    "body": ["if(${1:true}) {", "\t$0", "}"],
    "description": "Creates an if statement"
  },
  "struct": {
    "prefix": "struct",
    "body": ["struct ${1:Type} {", "\t${2:vec4} ${3:POSITION};$0", "}"],
    "description": "Creates a struct"
  },
  "Create Attributes": {
    "prefix": "@attribute",
    "body": [
      "struct ${0:a2v} {",
      "\t${1:vec4} ${2:POSITION};",
      "\t${3:vec2} ${4:TEXCOORD_0};",
      "\t${5:vec3} ${6:NORMAL};",
      "\t${7:vec4} ${8:TANGENT};",
      "}"
    ]
  },
  "shader": {
    "prefix": "Shader",
    "body": ["Shader \"${1:shaderName}\" {", "\t$0", "}"],
    "description": "Creates Shader block"
  },
  "subShader": {
    "prefix": "SubShader",
    "body": ["SubShader \"${1:subShaderName}\" {", "\t$0", "}"],
    "description": "Creates SubShader block"
  },
  "Pass": {
    "prefix": "Pass",
    "body": ["Pass \"${1:passName}\" {", "\t$0", "}"],
    "description": "Creates Pass block"
  },
  "Editor": {
    "prefix": "Editor",
    "body": ["Editor {", "\t$0", "}"],
    "description": "Creates Editor block"
  },
  "Properties": {
    "prefix": "Properties",
    "body": ["Properties {", "\t$0", "}"],
    "description": "Creates Properties block"
  },
  "Macros": {
    "prefix": "Macros",
    "body": ["Macros {", "\t$0", "}"],
    "description": "Creates Macros block"
  },
  "UIScript": {
    "prefix": "UIScript",
    "body": ["UIScript \"${1:path/to/script.ts}\";"],
    "description": "Creates UIScript binding"
  },
  "UsePass": {
    "prefix": "UsePass",
    "body": ["UsePass \"${1:shader/path/passName}\""],
    "description": "Creates UsePass reference"
  },
  "Tags": {
    "prefix": "Tags",
    "body": ["Tags { \"${1:pipelineStage}\" = \"${2:Forward}\" }"],
    "description": "Creates Tags block"
  },
  "Header": {
    "prefix": "Header",
    "body": ["Header(\"${1:Group}\") {", "\t$0", "}"],
    "description": "Creates Editor property group"
  },
  "Declare RasterState": {
    "prefix": "RasterState",
    "body": [
      "RasterState ${1:customRasterState} {",
      "\tCullMode = ${2:CullMode.Back};",
      "\tFillMode = ${3:FillMode.Solid};",
      "\tDepthBias = ${4:0};",
      "\tSlopeScaledDepthBias = ${5:0};",
      "}"
    ],
    "description": "Creates RasterState declaration"
  },
  "Declare BlendState": {
    "prefix": "BlendState",
    "body": [
      "BlendState ${1:customBlendState} {",
      "\tEnabled = ${2:true};",
      "\tColorBlendOperation = ${3:BlendOperation.Add};",
      "\tAlphaBlendOperation = ${4:BlendOperation.Add};",
      "\tSourceColorBlendFactor = ${5:BlendFactor.SourceAlpha};",
      "\tSourceAlphaBlendFactor = ${6:BlendFactor.One};",
      "\tDestinationColorBlendFactor = ${7:BlendFactor.OneMinusSourceAlpha};",
      "\tDestinationAlphaBlendFactor = ${8:BlendFactor.OneMinusSourceAlpha};",
      "\tColorWriteMask = ${9:ColorWriteMask.All};",
      "\tBlendColor = ${10:(1, 1, 1, 1)};",
      "\tAlphaToCoverage = ${11:false};",
      "}"
    ],
    "description": "Creates BlendState declaration"
  },
  "Declare DepthState": {
    "prefix": "DepthState",
    "body": [
      "DepthState ${1:customDepthState} {",
      "\tEnabled = ${2:true};",
      "\tWriteEnabled = ${3:true};",
      "\tCompareFunction = ${4:CompareFunction.LessEqual};",
      "}"
    ],
    "description": "Creates DepthState declaration"
  },
  "Declare StencilState": {
    "prefix": "StencilState",
    "body": [
      "StencilState ${1:customStencilState} {",
      "\tEnabled = ${2:false};",
      "\tReferenceValue = ${3:0};",
      "\tMask = ${4:255};",
      "\tWriteMask = ${5:255};",
      "\tCompareFunctionFront = ${6:CompareFunction.Always};",
      "\tCompareFunctionBack = ${7:CompareFunction.Always};",
      "\tPassOperationFront = ${8:StencilOperation.Keep};",
      "\tPassOperationBack = ${9:StencilOperation.Keep};",
      "\tFailOperationFront = ${10:StencilOperation.Keep};",
      "\tFailOperationBack = ${11:StencilOperation.Keep};",
      "\tZFailOperationFront = ${12:StencilOperation.Keep};",
      "\tZFailOperationBack = ${13:StencilOperation.Keep};",
      "}"
    ],
    "description": "Creates StencilState declaration"
  }
}
