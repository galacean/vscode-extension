{
  "name": "galacean-shaderlab",
  "displayName": "Galacean ShaderLab",
  "description": "ShaderLab language support for Galacean Engine",
  "version": "0.1.0-alpha.1",
  "author": "Mrkou47",
  "publisher": "Galacean",
  "license": "MIT",
  "engines": {
    "vscode": "^1.65.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/galacean/vscode-extension"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "galacean",
    "shaderlab",
    "shader",
    "glsl",
    "lsp"
  ],
  "contributes": {
    "languages": [
      {
        "id": "GalaceanShaderlab",
        "extensions": [
          ".gsl",
          ".gs"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./client/res/icons/shader.svg",
          "dark": "./client/res/icons/shader.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "GalaceanShaderlab",
        "scopeName": "source.shaderlab",
        "path": "./shaderlab.language.json"
      }
    ],
    "snippets": [
      {
        "language": "GalaceanShaderlab",
        "path": "./snippets.json"
      }
    ]
  },
  "main": "client/out/main",
  "scripts": {
    "vscode:prepublish": "npm run clear && npm run compile -- --mode production",
    "compile": "webpack",
    "rebuild": "npm run clear && npm run compile",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "clean": "rm -rf ./node_modules",
    "build": "webpack",
    "clear": "rm -rf ./client/out/* ./server/out/*",
    "swipe": "rm -rf ~/.galacean ~/galacean",
    "test": "vscode-test",
    "release": "standard-version && vsce package"
  },
  "activationEvents": [
    "onLanguage:GalaceanShaderlab"
  ],
  "dependencies": {
    "@galacean/engine": "1.6.13",
    "@galacean/engine-shaderlab": "^1.6.13",
    "prettydiff": "^101.2.6",
    "vscode-languageclient": "^8.1.0",
    "vscode-languageserver": "^8.1.0",
    "vscode-languageserver-textdocument": "^1.0.8"
  },
  "devDependencies": {
    "@galacean/engine-design": "^1.0.4",
    "@types/node": "^20.8.7",
    "@types/vscode": "1.65.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.8",
    "chevrotain": "^11.0.3",
    "standard-version": "^9.5.0",
    "ts-loader": "^9.5.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
