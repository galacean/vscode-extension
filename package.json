{
  "name": "galacean-vscode-extension",
  "version": "1.0.0",
  "description": "Extension for bridging Galacean and VSCode.",
  "main": "./client/out/extension",
  "publisher": "Galacean",
  "icon": "./assets/icons/logo-light.png",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "cd ./client && npm run build && cd ../server && npm run build && cd ..",
    "watch": "tsc -b -w",
    "lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
    "deploy": "vsce publish",
    "build": "vsce package"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [],
  "devDependencies": {
    "@types/mocha": "^9.1.0",
    "@types/node": "^16.18.34",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "eslint": "^8.35.0",
    "mocha": "^9.2.1",
    "resolve-tspaths": "^0.8.13",
    "typescript": "^5.1.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/galacean/vscode-extension.git"
  },
  "keywords": [
    "galacean",
    "vscode"
  ],
  "author": "yansw007@gmail.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/galacean/vscode-extension/issues"
  },
  "homepage": "https://github.com/galacean/vscode-extension.git",
  "contributes": {
    "languages": [
      {
        "id": "gshader",
        "extensions": [
          ".shader"
        ],
        "aliases": [
          "Galacean Shader",
          "gshader"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/icons/logo-dark.png",
          "dark": "./assets/icons/logo-light.png"
        }
      }
    ],
    "commands": [
      {
        "command": "galacean.update.project.list",
        "title": "Update Project",
        "category": "Galacean",
        "icon": "$(search-refresh)"
      },
      {
        "command": "galacean.update.asset",
        "title": "Sync to cloud",
        "category": "Galacean",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "galacean.storageCheck",
        "title": "Storage Check",
        "category": "Galacean"
      },
      {
        "command": "galacean.storageSet",
        "title": "Storage Set",
        "category": "Galacean"
      },
      {
        "command": "galacean.signin",
        "title": "Sign in",
        "category": "Galacean"
      },
      {
        "command": "galacean.userInfo",
        "title": "User Info",
        "category": "Galacean"
      },
      {
        "command": "galacean.create.script",
        "title": "Add Script",
        "category": "Galacean",
        "icon": "$(file-add)"
      },
      {
        "command": "galacean.create.shader",
        "title": "Add Shader",
        "category": "Galacean",
        "icon": "$(file-add)"
      },
      {
        "command": "galacean.glsl.show",
        "title": "Show Compiled GLSL Code",
        "category": "Galacean",
        "icon": "$(symbol-reference)"
      },
      {
        "command": "galacean.asset.rename",
        "title": "Rename",
        "category": "Galacean"
      },
      {
        "command": "galacean.asset.delete",
        "title": "Delete",
        "category": "Galacean"
      },
      {
        "command": "galacean.script.edit",
        "title": "Edit In Workspace",
        "category": "Galacean",
        "icon": "$(edit)"
      }
    ],
    "configuration": [
      {
        "title": "Galacean",
        "properties": {
          "galacean.server.host": {
            "description": "Specifies the galacean server host",
            "type": "string",
            "default": null
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "galacean-explorer",
          "title": "Galacean",
          "icon": "./assets/icons/icon.svg"
        }
      ]
    },
    "views": {
      "galacean-explorer": [
        {
          "id": "galacean-project-list",
          "name": "Projects"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "galacean-project-list",
        "contents": "Sign in to Galacean to display project list, asset list and more\n[Sign in to Galacean](command:galacean.signin)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId === gshader",
          "command": "galacean.glsl.show",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "galacean.update.project.list",
          "when": "view == galacean-project-list",
          "group": "navigation"
        },
        {
          "command": "galacean.update.asset",
          "when": "view == galacean-project-list",
          "group": "navigation"
        },
        {
          "command": "galacean.create.script",
          "when": "view == galacean-project-list",
          "group": "inline"
        },
        {
          "command": "galacean.create.shader",
          "when": "view === galacean-project-list",
          "group": "inline"
        }
      ],
      "view/item/context": [
        {
          "command": "galacean.asset.rename",
          "when": "viewItem == asset || viewItem == script"
        },
        {
          "command": "galacean.asset.delete",
          "when": "viewItem == asset || viewItem == script"
        },
        {
          "command": "galacean.update.project.list",
          "when": "viewItem == project",
          "group": "inline"
        },
        {
          "command": "galacean.script.edit",
          "when": "viewItem == script",
          "group": "inline"
        }
      ]
    }
  }
}
