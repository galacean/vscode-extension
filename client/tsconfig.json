{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020"],
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "paths": {
      "@data/*": ["./src/data/*"],
      "@/*": ["./src/*"],
      "@request/*": ["./src/request/*"]
    },
    "baseUrl": ".",
    "moduleResolution": "Node"
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test"]
}
