{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["client/src/**/*", "server/src/**/*"],
  "exclude": ["node_modules", ".vscode-test", "client/out", "server/out"]
}
